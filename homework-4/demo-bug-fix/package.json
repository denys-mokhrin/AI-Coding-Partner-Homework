{
  "name": "demo-bug-fix",
  "version": "1.0.0",
  "description": "Demo API for multi-agent bug fixing workshop",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --rootDir=.. --testMatch=**/tests/**/*.test.js --moduleDirectories=node_modules,demo-bug-fix/node_modules"
  },
  "jest": {
    "rootDir": "..",
    "testMatch": ["**/tests/**/*.test.js"],
    "modulePaths": ["<rootDir>/demo-bug-fix/node_modules"]
  },
  "keywords": [
    "demo",
    "api",
    "bug-fixing",
    "multi-agent"
  ],
  "author": "SPD Tech Training",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.1"
  }
}
